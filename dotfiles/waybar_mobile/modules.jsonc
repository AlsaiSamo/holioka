{
    "custom/keeb": {
        "format": "ï„œ",
        "on-click": "busctl call --user sm.puri.OSK0 /sm/puri/OSK0 sm.puri.OSK0 SetVisible b $(if [ \"$(busctl get-property --user sm.puri.OSK0 /sm/puri/OSK0 sm.puri.OSK0 Visible | tail -c+3)\" = \"false\" ]; then echo 'true'; else echo 'false'; fi)"
    },

    "group/bat": {
        "orientation": "vertical",
        "modules": [ "battery", "backlight" ]
    },

    "group/load": {
        "orientation": "vertical",
        "modules": [ "network", "memory" ]
    },

    "clock#time": {
        "interval": 15,
        "format": "{:%H:%M}",
        "tooltip-format": "{:%Y-%m-%d %H:%M}",
        "justify": "center"
    },

    "sway/workspaces": {
	    "format": "{icon}",
	    "format-icons": { "10": "0" },
        "disable-scroll-wraparound": true,
	    "disable-auto-back-and-forth": true,
        "warp-on-scroll": false
	},

    "cpu": {
        "interval": 10,
        "format": "ï’¼ {usage}%"
    },

    "memory": {
        "interval": 30,
        "format": "َ°کڑ {percentage}%"
    },

    "battery": {
        "format-icons": ["َ°‚ژ", "َ°پ؛", "َ°پ»", "َ°پ¼", "َ°پ½", "َ°پ¾", "َ°پ؟", "َ°‚€", "َ°‚پ", "َ°‚‚", "َ°پ¹"],
        "format": "{icon} {capacity}%"
    },

    "network": {
        "interval": 10,
        "format-wifi": "{icon}",
        "format-icons": ["َ°¤¯â€†", "َ°¤ںâ€†", "َ°¤¢â€†", "َ°¤¥â€†", "َ°¤¨â€†"],
        "tooltip-format": "{ifname}\n{ipaddr}\nî«´ {bandwidthUpBits} / î«³ {bandwidthDownBits}",
        "tooltip-format-wifi": "َ°–© {essid} / {signalStrength}%\n{ipaddr}\nî«´ {bandwidthUpBits} / î«³ {bandwidthDownBits}"
    },

    "pulseaudio": {
        "format-muted": "ï‘¦",
        "format": "ï€¨ {volume}%",
        "on-click": "pactl set-sink-mute @DEFAULT_SINK@ toggle"
    },

    "pulseaudio/slider": {
        "orientation": "vertical"
    },

    "tray": {
	    "spacing": 6
	},

    "idle_inhibitor": {
        "format": "{icon}",
        "format-icons": {
            "activated": "َ°…¶",
            "deactivated": "َ°¾ھ"
        },
        "start-activated": "false"
    },

    "sway/language": {
	    "format": "<span text_transform='lowercase'>{shortDescription}</span>",
	    "tooltip-format": "{long}"
	}

}
